# PostgreSQL connection string (required)
# For Supabase:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# For local PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mits_rtb
DATABASE_URL=

# JWT secret (generate a strong random string with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-random-secret

# Optional: ImgBB API key for image uploads
# If not set, images will be stored locally under /uploads
IMGBB_API_KEY=

# Server port (default: 3001)
PORT=3001

# Environment
NODE_ENV=development

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
